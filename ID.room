// UROOM – Universal‑Raum

const UROOM = {
    id: "uroom",
    version: "1.0",
    type: "UNIVERSAL",
    state: "ACTIVE",

    root: TOR.ROOT.9x9,
    identity: ID_ROOM,

    vector: ID_ROOM.vector,   // Vector‑Kennung weitergegeben

    getVector(code) {
        return this.vector.map[code] || "NO-VECTOR";
    }
};
